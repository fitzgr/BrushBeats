{
  "version": 1,
  "description": "Starter image overlay manifest for young-person BrushBeats themes. Each theme uses consistent overlay slots so the UI can lazy-load only the selected theme.",
  "basePath": "assets/overlays/kids/",
  "slots": [
    "background",
    "frame",
    "mascot",
    "progressMarker",
    "quadrantReward",
    "completionReward",
    "beatAccent"
  ],
  "themes": [
    {
      "id": "space-adventure",
      "name": "Space Adventure",
      "ageBands": ["kids", "preteens"],
      "mood": "Curious, heroic, cosmic",
      "paletteHint": ["midnight blue", "purple", "yellow", "white"],
      "overlays": {
        "background": "space-adventure/background.svg",
        "frame": "space-adventure/frame.svg",
        "mascot": "space-adventure/rocket-mascot.svg",
        "progressMarker": "space-adventure/planet-progress.svg",
        "quadrantReward": "space-adventure/shooting-star.svg",
        "completionReward": "space-adventure/mission-complete-badge.svg",
        "beatAccent": "space-adventure/music-satellite.svg"
      }
    },
    {
      "id": "jungle-safari",
